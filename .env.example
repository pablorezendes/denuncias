# ============================================================
# Canal de Denúncias HSFA - Variáveis de Ambiente
# ============================================================
# Copie este arquivo para `.env` e preencha os valores.
# O arquivo `.env` NÃO deve ser commitado (já está no .gitignore).
# ============================================================

# ------------------------------------------------------------
# Supabase (fase atual - será removido após migração)
# ------------------------------------------------------------
# Obtenha em: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ------------------------------------------------------------
# API Backend (após dockerização - Fase 5)
# ------------------------------------------------------------
# URL da API que o frontend vai consumir
VITE_API_URL=http://localhost:3001/api

# ------------------------------------------------------------
# PostgreSQL (Fase 5 - banco local)
# ------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=hsfa_admin
DB_PASSWORD=change-me-use-strong-password
DB_NAME=denuncias_hsfa

# Connection string pronta (usada pelo backend)
DATABASE_URL=postgresql://hsfa_admin:change-me-use-strong-password@postgres:5432/denuncias_hsfa

# ------------------------------------------------------------
# MinIO (Object Storage - substitui Supabase Storage)
# ------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-use-strong-password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=anexos-denuncias
MINIO_USE_SSL=false

# ------------------------------------------------------------
# Redis (rate limiting e cache)
# ------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-use-strong-password

# ------------------------------------------------------------
# JWT (autenticação do backend novo)
# ------------------------------------------------------------
# Gere com: openssl rand -base64 64
JWT_SECRET=change-me-generate-with-openssl-rand-base64-64
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------------------------
# Aplicação
# ------------------------------------------------------------
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost
LOG_LEVEL=info

# ------------------------------------------------------------
# Email (Resend - notificações)
# ------------------------------------------------------------
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=noreply@hsfasaude.com.br
EMAIL_FROM_NAME=Canal de Denúncias HSFA

# ------------------------------------------------------------
# pgAdmin (ferramenta opcional)
# ------------------------------------------------------------
PGADMIN_EMAIL=admin@hsfasaude.com.br
PGADMIN_PASSWORD=change-me-use-strong-password

# ------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MIN=15
RATE_LIMIT_DENUNCIA_MAX=3
RATE_LIMIT_DENUNCIA_WINDOW_MIN=60
